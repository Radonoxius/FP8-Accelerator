module controller (
    input  wire         a_clk,
    input  wire         reset_n,
    input  wire         write,
    input  wire [127:0] writedata,
	 input wire [7:0] address,
    input  wire         read,
    output reg  [127:0] readdata
);
    reg [127:0] in_storage;
	 reg [127:0] opcode;
	 
	 reg [127:0] out_storage;
	 
    wire [63:0] vec_results;

    vecUnit2 u(in_storage, opcode, vec_results);

    always @(posedge a_clk or negedge reset_n) begin
        if (!reset_n) begin
            in_storage     <= 128'd0;
				opcode <= 128'd0;
            readdata    <= 128'd0;
        end
		  
		  else if(write && address == 8'b00000000)
				in_storage <= writedata;
		  
		  else if(write && address == 8'b00010000)
				opcode <= { writedata[127:125], 125'd0 };
				
		  else if(read && address == 8'b00100000)
				readdata <= vec_results;
    end

endmodule
